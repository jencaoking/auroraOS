CONFIG_BOARD_LM3S6965_QB=y
# CONFIG_BOARD_MIBAND8 is not set
# CONFIG_BOARD_QEMU_RV32_VIRT is not set
# CONFIG_BOARD_NUCLEO_L031K6 is not set
CONFIG_BOARD="lm3s6965-qb"
CONFIG_SCHEDULER=y
CONFIG_MAX_TASKS=4
CONFIG_TICK_RATE_HZ=1000
CONFIG_VFS=y
CONFIG_FS_RAMFS=y
CONFIG_FS_PROCFS=y
CONFIG_DEVICE_UART=y
CONFIG_TIMER_MANAGER=y
CONFIG_WORK_QUEUE=y
CONFIG_NETWORKING=y
CONFIG_NET_LWIP=y
CONFIG_LUA_VM=y
CONFIG_OTA_DEV_MODE=y
CONFIG_WATCHDOG=y
