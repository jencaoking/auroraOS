CONFIG_BOARD="lm3s6965-qb"

#
# System Core Configuration
#
CONFIG_SCHEDULER=y
CONFIG_MAX_TASKS=16
CONFIG_TICK_RATE_HZ=1000
# end of System Core Configuration

#
# File Systems
#
CONFIG_VFS=y
CONFIG_FS_RAMFS=y
CONFIG_FS_PROCFS=y
# end of File Systems

#
# Device Drivers
#
CONFIG_DEVICE_UART=y
CONFIG_TIMER_MANAGER=y
CONFIG_WORK_QUEUE=y
# end of Device Drivers

#
# Networking
#
CONFIG_NETWORKING=y
CONFIG_NET_LWIP=y
CONFIG_NET_DEFAULT_IP="10.0.2.15"
CONFIG_NET_DEFAULT_MAC="00:11:22:33:44:55"
# end of Networking
