# CONFIG_BOARD_LM3S6965_QB is not set
CONFIG_BOARD_MIBAND8=y
CONFIG_BOARD="miband8"

#
# System Core Configuration
#
CONFIG_SCHEDULER=y
CONFIG_MAX_TASKS=8
CONFIG_TICK_RATE_HZ=1000
# end of System Core Configuration

#
# File Systems
#
CONFIG_VFS=y
CONFIG_FS_RAMFS=y
CONFIG_FS_PROCFS=y
# end of File Systems

#
# Device Drivers
#
CONFIG_DEVICE_UART=y
CONFIG_TIMER_MANAGER=y
CONFIG_WORK_QUEUE=y
# end of Device Drivers

#
# Networking
#
# CONFIG_NETWORKING is not set
# end of Networking

#
# Applications and runtimes
#
CONFIG_LUA_VM=y
# end of Applications and runtimes

CONFIG_TARGET_MIBAND=y

#
# System & Architecture
#
CONFIG_ARCH_CORTEX_M4F=y
CONFIG_SYSTEM_CORE_CLOCK=96000000
# end of System & Architecture

#
# Kernel & Power Management
#
CONFIG_POWER_MANAGER=y
CONFIG_WRIST_WAKE_DETECTOR=y
CONFIG_FRAME_SCHEDULER_V2=y
# end of Kernel & Power Management

#
# Hardware Drivers
#
CONFIG_DISPLAY_ST7789=y
CONFIG_GESTURE_RECOGNIZER=y
CONFIG_SENSOR_GH3026=y
CONFIG_SENSOR_BHI260AP=y
# end of Hardware Drivers

#
# Network & Connectivity
#
CONFIG_BLE_STACK=y
# end of Network & Connectivity

#
# Application Layer
#
CONFIG_WATCH_APP=y
CONFIG_FONT_ENGINE=y
# end of Application Layer
